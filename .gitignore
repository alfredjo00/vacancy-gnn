# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
venv/

# ML artifacts
wandb/
mlruns/
checkpoints/
*.ckpt
*.pt

# Data (large; use data/sample/ for the committed subset)
data/full/
*.parquet
*.db
!data/sample/**

# Hidden files: tool caches, editor state, local config. Only the few
# tracked ones are allowed back in.
.*
!/.github/
!/.gitignore
!/.pre-commit-config.yaml

# Root-level documents are local notes; the README is the public one.
/*.md
!/README.md

logs/
